// ===========================================
//  西幻风自定义样式
//  Western Fantasy Theme for Volantis
// ===========================================

// -- Variables
$gold = #d4a843
$gold-light = #e6c873
$gold-hover = #f0d080
$gold-dim = rgba($gold, 0.15)
$bg-deep = #0d0221
$bg-card = #15082e
$bg-block = #1a0e30
$text-primary = #e8d5b7
$text-heading = #f5e6c8
$text-muted = #a89070
$font-display = 'Cinzel', serif
$font-body = 'Cormorant Garamond', serif
$font-code = 'Fira Code', monospace

// ===========================================
//  星空背景
// ===========================================
#l_body
  background: linear-gradient(180deg, $bg-deep 0%, #1a0a2e 50%, $bg-deep 100%)
  position: relative

  &::before
    content: ""
    position: fixed
    top: 0
    left: 0
    width: 100%
    height: 100%
    pointer-events: none
    z-index: 0
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba($gold, 0.15), transparent),
      radial-gradient(1px 1px at 30% 60%, rgba($gold, 0.10), transparent),
      radial-gradient(1.5px 1.5px at 50% 10%, rgba(255, 255, 255, 0.12), transparent),
      radial-gradient(1px 1px at 70% 40%, rgba($gold, 0.08), transparent),
      radial-gradient(1px 1px at 90% 80%, rgba(255, 255, 255, 0.10), transparent),
      radial-gradient(1.5px 1.5px at 20% 90%, rgba($gold, 0.12), transparent),
      radial-gradient(1px 1px at 80% 15%, rgba(255, 255, 255, 0.08), transparent),
      radial-gradient(1px 1px at 45% 45%, rgba($gold, 0.10), transparent),
      radial-gradient(1.5px 1.5px at 65% 75%, rgba(255, 255, 255, 0.06), transparent),
      radial-gradient(1px 1px at 15% 55%, rgba($gold, 0.10), transparent)

  > *
    position: relative
    z-index: 1

// ===========================================
//  卡片 - 魔法 parchment 质感
// ===========================================
.white-box
  background: linear-gradient(135deg, rgba($bg-card, 0.95), rgba(#1e0f3a, 0.95))
  border: 1px solid $gold-dim
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba($gold, 0.05)
  backdrop-filter: blur(10px)

// ===========================================
//  导航栏
// ===========================================
#l_header
  background: linear-gradient(180deg, rgba($bg-deep, 0.9), rgba($bg-card, 0.85))
  border-bottom: 1px solid rgba($gold, 0.2)

  .logo a
    font-weight: 700
    color: $gold !important
    text-shadow: 0 0 10px rgba($gold, 0.3)

  .nav-list a
    color: $text-primary !important
    transition: all 0.3s ease

    &:hover
      color: $gold !important
      text-shadow: 0 0 8px rgba($gold, 0.4)

// ===========================================
//  文章
// ===========================================
.article-title
  color: $text-heading !important

.post-article, .post
  .article-entry
    font-size: 1.1rem
    line-height: 1.8
    color: $text-primary

    h1, h2, h3, h4, h5, h6
      color: $text-heading !important
      text-shadow: 0 0 15px rgba($gold, 0.15)

    h2
      border-bottom: 1px solid rgba($gold, 0.2)
      padding-bottom: 8px

    a
      color: $gold-light !important
      text-decoration: none
      border-bottom: 1px dotted rgba($gold-light, 0.3)
      transition: all 0.3s ease

      &:hover
        color: $gold-hover !important
        border-bottom-color: $gold-hover
        text-shadow: 0 0 8px rgba($gold-hover, 0.3)

    blockquote
      border-left: 3px solid $gold
      background: rgba($gold, 0.05)
      padding: 12px 20px
      font-style: italic
      color: #d4c4a8

    pre
      background: $bg-block !important
      border: 1px solid $gold-dim
      box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.3)

    code
      color: $gold-hover

    img
      border-radius: 8px
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3)

    table
      border-collapse: collapse
      width: 100%

      th
        background: rgba($gold, 0.15)
        color: $text-heading
        font-size: 0.95rem
        border-bottom: 2px solid rgba($gold, 0.3)

      td, th
        border: 1px solid $gold-dim
        padding: 8px 12px

// ===========================================
//  侧边栏
// ===========================================
#sidebar
  .sidebar-card
    background: linear-gradient(135deg, rgba($bg-card, 0.95), rgba(#1e0f3a, 0.95))
    border: 1px solid $gold-dim

  .widget-title
    color: $gold !important

  .blogger
    .avatar img
      border: 2px solid rgba($gold, 0.3)
      box-shadow: 0 0 15px rgba($gold, 0.2)

    .name
      color: $text-heading !important

    .subtitle
      font-style: italic
      color: #d4c4a8

// ===========================================
//  页脚
// ===========================================
#l_footer
  border-top: 1px solid rgba($gold, 0.15)
  color: $text-muted

// ===========================================
//  组件样式
// ===========================================

// 标签云
.tagcloud a
  color: $gold !important
  transition: all 0.3s ease

  &:hover
    color: $gold-hover !important
    text-shadow: 0 0 8px rgba($gold-hover, 0.3)

// 分类列表
.category-list a
  color: $text-primary !important
  transition: all 0.3s ease

  &:hover
    color: $gold !important

// 按钮
.btn
  background: linear-gradient(135deg, $gold, #c9951e) !important
  border: none !important
  color: $bg-deep !important
  box-shadow: 0 2px 10px rgba($gold, 0.3)
  transition: all 0.3s ease !important

  &:hover
    background: linear-gradient(135deg, $gold-light, $gold) !important
    box-shadow: 0 4px 20px rgba($gold, 0.4)
    transform: translateY(-1px)

// 分页
.pagination
  .page-number.current
    background: $gold !important
    border-color: $gold !important
    color: $bg-deep !important

  a:hover
    color: $gold !important

// 搜索框
.s-search input
  background: rgba(255, 255, 255, 0.05) !important
  border: 1px solid rgba($gold, 0.2) !important
  color: $text-primary !important

  &:focus
    border-color: $gold !important
    box-shadow: 0 0 10px rgba($gold, 0.2)

// Cover
#cover .cover-info
  .cover-title
    text-shadow: 0 0 20px rgba($gold, 0.3)

  .cover-subtitle
    font-style: italic

// ===========================================
//  滚动条
// ===========================================
::-webkit-scrollbar-track
  background: $bg-deep

::-webkit-scrollbar-thumb
  background: linear-gradient(180deg, $gold, #c9951e)
  border-radius: 3px

*
  scrollbar-width: thin
  scrollbar-color: $gold $bg-deep
