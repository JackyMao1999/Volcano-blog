// ===========================================
// 西幻风自定义样式 - Western Fantasy Theme
// ===========================================

// Google Fonts
@import url("https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Fira+Code:wght@400;600&display=swap")

// 页面背景 - 星空效果
#l_body
  background: linear-gradient(180deg, #0d0221 0%, #1a0a2e 50%, #0d0221 100%)
  position: relative

// 给背景添加微弱的星点效果
#l_body::before
  content: ""
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  background-image:
    radial-gradient(1px 1px at 10% 20%, rgba(212, 168, 67, 0.15), transparent),
    radial-gradient(1px 1px at 30% 60%, rgba(212, 168, 67, 0.1), transparent),
    radial-gradient(1.5px 1.5px at 50% 10%, rgba(255, 255, 255, 0.12), transparent),
    radial-gradient(1px 1px at 70% 40%, rgba(212, 168, 67, 0.08), transparent),
    radial-gradient(1px 1px at 90% 80%, rgba(255, 255, 255, 0.1), transparent),
    radial-gradient(1.5px 1.5px at 20% 90%, rgba(212, 168, 67, 0.12), transparent),
    radial-gradient(1px 1px at 80% 15%, rgba(255, 255, 255, 0.08), transparent),
    radial-gradient(1px 1px at 45% 45%, rgba(212, 168, 67, 0.1), transparent),
    radial-gradient(1.5px 1.5px at 65% 75%, rgba(255, 255, 255, 0.06), transparent),
    radial-gradient(1px 1px at 15% 55%, rgba(212, 168, 67, 0.1), transparent)
  pointer-events: none
  z-index: 0

// 内容层保持在星空之上
#l_body > *
  position: relative
  z-index: 1

// 卡片 - 魔法 parchment 质感
.white-box
  background: linear-gradient(135deg, rgba(21, 8, 46, 0.95) 0%, rgba(30, 15, 58, 0.95) 100%)
  border: 1px solid rgba(212, 168, 67, 0.15)
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(212, 168, 67, 0.05)
  backdrop-filter: blur(10px)

// 导航栏 - 魔法镶边
#l_header
  background: linear-gradient(180deg, rgba(13, 2, 33, 0.9) 0%, rgba(21, 8, 46, 0.85) 100%)
  border-bottom: 1px solid rgba(212, 168, 67, 0.2)

  .logo a
    font-family: 'Cinzel', serif !important
    font-weight: 700
    color: #d4a843 !important
    text-shadow: 0 0 10px rgba(212, 168, 67, 0.3)

  .nav-list a
    font-family: 'Cinzel', serif !important
    color: #e8d5b7 !important
    transition: all 0.3s ease

    &:hover
      color: #d4a843 !important
      text-shadow: 0 0 8px rgba(212, 168, 67, 0.4)

// 文章标题添加装饰
.article-title
  font-family: 'Cinzel', serif !important
  color: #f5e6c8 !important

// 文章正文 - 羊皮卷风格
.post-article, .post
  .article-entry
    font-family: 'Cormorant Garamond', serif !important
    font-size: 1.1rem
    line-height: 1.8
    color: #e8d5b7

    h1, h2, h3, h4, h5, h6
      font-family: 'Cinzel', serif !important
      color: #f5e6c8 !important
      text-shadow: 0 0 15px rgba(212, 168, 67, 0.15)

    h2
      border-bottom: 1px solid rgba(212, 168, 67, 0.2)
      padding-bottom: 8px

    a
      color: #e6c873 !important
      text-decoration: none
      border-bottom: 1px dotted rgba(230, 200, 115, 0.3)
      transition: all 0.3s ease

      &:hover
        color: #f0d080 !important
        border-bottom-color: #f0d080
        text-shadow: 0 0 8px rgba(240, 208, 128, 0.3)

    blockquote
      border-left: 3px solid #d4a843
      background: rgba(212, 168, 67, 0.05)
      padding: 12px 20px
      font-style: italic
      color: #d4c4a8

    // 代码块 - 魔法符文风格
    pre, code
      font-family: 'Fira Code', monospace !important

    pre
      background: #1a0e30 !important
      border: 1px solid rgba(212, 168, 67, 0.1)
      box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.3)

    code
      color: #f0d080

    img
      border-radius: 8px
      box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3)

    table
      border-collapse: collapse
      width: 100%

      th
        background: rgba(212, 168, 67, 0.15)
        color: #f5e6c8
        font-family: 'Cinzel', serif
        border-bottom: 2px solid rgba(212, 168, 67, 0.3)

      td, th
        border: 1px solid rgba(212, 168, 67, 0.1)
        padding: 8px 12px

// 侧边栏
#sidebar
  .sidebar-card
    background: linear-gradient(135deg, rgba(21, 8, 46, 0.95) 0%, rgba(30, 15, 58, 0.95) 100%)
    border: 1px solid rgba(212, 168, 67, 0.15)

  .widget-title
    font-family: 'Cinzel', serif !important
    color: #d4a843 !important

  .blogger
    .avatar img
      border: 2px solid rgba(212, 168, 67, 0.3)
      box-shadow: 0 0 15px rgba(212, 168, 67, 0.2)

    .name
      font-family: 'Cinzel', serif !important
      color: #f5e6c8 !important

    .subtitle
      font-family: 'Cormorant Garamond', serif !important
      font-style: italic
      color: #d4c4a8

// 页脚
#l_footer
  border-top: 1px solid rgba(212, 168, 67, 0.15)
  color: #a89070

// 标签云
.tagcloud
  a
    color: #d4a843 !important
    transition: all 0.3s ease

    &:hover
      color: #f0d080 !important
      text-shadow: 0 0 8px rgba(240, 208, 128, 0.3)

// 分类
.category-list
  a
    color: #e8d5b7 !important
    transition: all 0.3s ease

    &:hover
      color: #d4a843 !important

// 按钮
.btn
  background: linear-gradient(135deg, #d4a843 0%, #c9951e 100%) !important
  border: none !important
  color: #1a0a2e !important
  font-family: 'Cinzel', serif !important
  box-shadow: 0 2px 10px rgba(212, 168, 67, 0.3)
  transition: all 0.3s ease !important

  &:hover
    background: linear-gradient(135deg, #e6c873 0%, #d4a843 100%) !important
    box-shadow: 0 4px 20px rgba(212, 168, 67, 0.4)
    transform: translateY(-1px)

// 分页
.pagination
  .page-number.current
    background: #d4a843 !important
    border-color: #d4a843 !important
    color: #1a0a2e !important

  a:hover
    color: #d4a843 !important

// 搜索框
.s-search
  input
    background: rgba(255, 255, 255, 0.05) !important
    border: 1px solid rgba(212, 168, 67, 0.2) !important
    color: #e8d5b7 !important

    &:focus
      border-color: #d4a843 !important
      box-shadow: 0 0 10px rgba(212, 168, 67, 0.2)

// 滚动条
::-webkit-scrollbar-track
  background: #0d0221

::-webkit-scrollbar-thumb
  background: linear-gradient(180deg, #d4a843, #c9951e)
  border-radius: 3px

// 标签页归档 等独立页面
#archive, #tag, #category
  .article-title
    font-family: 'Cinzel', serif !important

// Cover 区域
#cover
  .cover-info
    .cover-title
      font-family: 'Cinzel', serif !important
      text-shadow: 0 0 20px rgba(212, 168, 67, 0.3)

    .cover-subtitle
      font-family: 'Cormorant Garamond', serif !important
      font-style: italic

// 自定义滚动条全局
*
  scrollbar-width: thin
  scrollbar-color: #d4a843 #0d0221
